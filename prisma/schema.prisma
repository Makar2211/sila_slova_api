generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x"]

  // Optional Prisma Client Generator configuration
  runtime                = "nodejs" // <-- Important part 2
  moduleFormat           = "cjs"
  generatedFileExtension = "ts" // <-- Important part 3
}

datasource db {
  provider = "postgresql"
}


enum Role {
  OWNER
  ADMINISTRATOR
  REVISIONER
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  PENDING
  CANCELLED
}

enum Lang {
  EN
  RU
  UA
}


model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  displayName   String
  baseRole      Role
  status        UserStatus @default(ACTIVE)
  preferredLang Lang       @default(EN)
  createdAt     DateTime   @default(now())
  createdBy     String?
  deactivatedAt DateTime?

  sessions       AppSession[]
  editCandidates EditCandidate[]
  auditEvents    AuditEvent[]

  @@map("users")
}

model AppSession {
  id             String   @id @default(cuid())
  userId         String
  baseRole       Role
  activeRoleMode Role
  createdAt      DateTime @default(now())
  lastSeenAt     DateTime @updatedAt
  expiresAt      DateTime
  isRevoked      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("app_sessions")
}


model EditCandidate {
  id               String    @id @default(cuid())
  lessonId         String
  sceneId          String?
  stepId           String?
  locationKey      String
  field            String
  candidateType    String
  originalValue    String    @db.Text
  proposedValue    String    @db.Text
  languageCode     String?
  sourceLanguage   String?
  translatedValues Json?
  status           String    @default("pending")
  authorUserId     String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNote       String?
  withdrawnAt      DateTime?
  publishVersionId String?

  author         User            @relation(fields: [authorUserId], references: [id])
  publishVersion PublishVersion? @relation(fields: [publishVersionId], references: [id])

  @@index([lessonId, status])
  @@index([authorUserId])
  @@map("edit_candidates")
}

model PublishVersion {
  id            String   @id @default(cuid())
  lessonId      String
  versionNumber Int
  snapshot      Json
  description   String?
  isActive      Boolean  @default(false)
  publishedBy   String
  publishedAt   DateTime @default(now())

  candidates EditCandidate[]

  @@index([lessonId, isActive])
  @@map("publish_versions")
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String
  actionType  String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@map("audit_events")
}

// ─── Lesson content ───────────────────────────────────────────────────────────

model Lesson {
  id             String   @id // e.g. "1A", "1B", "13A"
  title          Json     // { ru: string, en: string, uk: string }
  defaultLang    String   @default("ru")
  supportedLangs String[]

  scenes Scene[]
  steps  Step[]

  @@map("lessons")
}

model Scene {
  id             String @id @default(cuid())
  lessonId       String
  sceneKey       String 
  title          Json   
  firstStepIndex Int
  sortOrder      Int

  lesson Lesson @relation(fields: [lessonId], references: [id])
  steps  Step[]

  @@unique([lessonId, sceneKey])
  @@index([lessonId])
  @@map("scenes")
}

model Step {
  id           String  @id @default(cuid())
  lessonId     String
  sceneId      String  // FK → Scene.id (cuid)
  stepKey      String  // "sc1_1", "sc2_13", etc.
  stepType     String  // theory | reflection | instruction | single_choice | open_question
  textAudience String  // teacher | shared
  prompt       Json    // { ru, en, uk }
  options      Json?   // [{ id, text: { ru, en, uk } }] for single_choice
  correctAnswer Json?   // String for single_choice, String[] for multi_choice
  explanation  Json?   // { ru, en, uk }
  imagePath    String?
  sortOrder    Int

  lesson Lesson @relation(fields: [lessonId], references: [id])
  scene  Scene  @relation(fields: [sceneId], references: [id])

  @@unique([lessonId, stepKey])
  @@index([lessonId])
  @@index([sceneId])
  @@map("steps")
}
